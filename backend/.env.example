# Copy this file to .env and fill in your values

# Supabase / PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Auth
SECRET_KEY=your-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS - add your frontend URL
FRONTEND_URL=http://localhost:5173

# App
APP_NAME=NUP Diaspora Convention 2026 — Los Angeles
CONFERENCE_START_DATE=2026-08-12
CONFERENCE_END_DATE=2026-08-16

# Stripe Webhook
# Get this from Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Payment Link IDs — the slug from each buy.stripe.com/<ID> URL
STRIPE_LINK_CONVENTION_FULL=fZucN60BeYaR20j
STRIPE_LINK_CONVENTION_HALF=
STRIPE_LINK_BOAT_CRUISE_FULL=
STRIPE_LINK_BOAT_CRUISE_PARTIAL=d09n8Zq3cn
